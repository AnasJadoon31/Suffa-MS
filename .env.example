ENVIRONMENT=production
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql+asyncpg://mms:replace-db-password@postgres-host:5432/mms
REDIS_URL=redis://redis-host:6379/0
API_BASE=http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000
DEFAULT_TENANT=default
MADRASA_NAME=Suffa Madrasa
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# External S3-compatible object storage (MinIO)
MINIO_ENDPOINT=http://minio-host:9000
MINIO_PUBLIC_URL=https://minio.example.com
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=mms-files

# File-upload guardrails (OWASP A04/A08) — optional, sane defaults baked in.
# Comma-separated MIME allowlist for presigned uploads:
# UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
# Max declared upload size in bytes (default 20MB):
# UPLOAD_MAX_SIZE_BYTES=20971520

# Optional direct WhatsApp document delivery (Evolution API v2).
# Without these, share buttons fall back to a text-only wa.me link.
EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_KEY=replace-with-evolution-api-key
EVOLUTION_INSTANCE=suffa-ms
